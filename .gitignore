# 忽略虛擬環境
backend/.venv/

# 忽略環境變數檔 (保護資料庫密碼)
backend/.env
frontend/.env

# 忽略 Python 編譯檔
__pycache__/
*.pyc

# 忽略 VS Code 個人設定 (保留推薦設定)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# frontend 的忽略規則
# Logs
frontend/logs
frontend/*.log
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/lerna-debug.log*

frontend/node_modules
frontend/dist
frontend/dist-ssr
frontend/*.local

# Editor directories and files
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?